# ConvertChain Go Engine
ENVIRONMENT=development
DB_URL=postgresql://Convertchain:YOUR_DB_PASSWORD@127.0.0.1:5433/convertchain_db?sslmode=disable
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@127.0.0.1:6379/0
SERVICE_TOKEN=
ADMIN_API_TOKEN=

# Vault (optional local overlay)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=devroot

# Local development toggles
# Forced off automatically in production even if set to true.
AUTO_APPROVE_KYC=true
BINANCE_USE_TESTNET=true
BYBIT_USE_TESTNET=true
GRAPH_USE_SANDBOX=true
GRAPH_WEBHOOK_SECRET=
GRAPH_WEBHOOK_PUBLIC_BASE_URL=

# Optional env fallback provider credentials
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
GRAPH_API_KEY=
