# ConvertChain local stack defaults
# Copy to .env for local Docker Compose. Replace every dev value before staging or production.

ENVIRONMENT=development

# Database
DB_USER=convertchain
DB_PASSWORD=DevPassword123!
DB_NAME=convertchain_db
DB_URL=postgresql://convertchain:DevPassword123!@127.0.0.1:5433/convertchain_db?sslmode=disable

# Redis
REDIS_PASSWORD=DevPassword123!
REDIS_URL=redis://:DevPassword123!@127.0.0.1:6379/0

# Internal service authentication
SERVICE_TOKEN=dev-service-token
ADMIN_API_TOKEN=dev-admin-token

# Vault (optional local overlay)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=devroot

# Local development toggles
# AUTO_APPROVE_KYC is forced off automatically in production even if set to true.
AUTO_APPROVE_KYC=true
KYC_PRIMARY_PROVIDER=sumsub
BINANCE_USE_TESTNET=true
BYBIT_USE_TESTNET=true
BYBIT_FALLBACK_ENABLED=false
GRAPH_USE_SANDBOX=true
GRAPH_WEBHOOK_SECRET=dev-graph-webhook-secret
GRAPH_WEBHOOK_PUBLIC_BASE_URL=http://localhost:9000

# Optional provider credentials.
# Leave empty for the local USDT sandbox smoke path.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
GRAPH_API_KEY=
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
SMILE_ID_USE_SANDBOX=true
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_USE_SANDBOX=true
SUMSUB_WEBHOOK_SECRET=
SUMSUB_WEBHOOK_PUBLIC_BASE_URL=http://localhost:9000
SUMSUB_TIER1_LEVEL_NAME=telegram-tier1
SUMSUB_TIER2_LEVEL_NAME=telegram-tier2
SUMSUB_TIER3_LEVEL_NAME=telegram-tier3
SUMSUB_TIER4_LEVEL_NAME=telegram-tier4
SUMSUB_WEBSDK_LINK_TTL_SECONDS=1800

# Telegram-only launch channel defaults.
ENABLED_CHANNELS=telegram
TELEGRAM_BOT_TOKEN=
# In production, either set TELEGRAM_WEBHOOK_SECRET and configure it with Telegram,
# or explicitly set TELEGRAM_TRUSTED_DELIVERY=true if your ingress layer authenticates delivery.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_TRUSTED_DELIVERY=false

# WhatsApp is disabled by default for the first production launch.
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Blockchain deposit monitoring.
# Local default is sandbox. Production mode requires public chain/RPC access.
BLOCKCHAIN_MONITOR_MODE=sandbox
BTC_BLOCKSTREAM_API_BASE_URL=https://blockstream.info/api
BTC_DEPOSIT_ADDRESS=
BTC_DEPOSIT_DETECTION_CONFIRMATIONS=1
BTC_DEPOSIT_FINALITY_CONFIRMATIONS=2
BTC_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0

# Native EVM assets. Use exchange deposit addresses for BTC/ETH/BNB flows.
ETH_DEPOSIT_NETWORK=ethereum
ETH_DEPOSIT_ADDRESS=
BINANCE_ETH_DEPOSIT_ADDRESS=
BYBIT_ETH_DEPOSIT_ADDRESS=
ETH_RPC_URL=
ETH_DEPOSIT_DETECTION_CONFIRMATIONS=1
ETH_DEPOSIT_FINALITY_CONFIRMATIONS=12
ETH_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0

BNB_DEPOSIT_NETWORK=bsc
BNB_BSC_DEPOSIT_ADDRESS=
BINANCE_BNB_DEPOSIT_ADDRESS=
BYBIT_BNB_DEPOSIT_ADDRESS=
BSC_RPC_URL=
BNB_BSC_DEPOSIT_DETECTION_CONFIRMATIONS=1
BNB_BSC_DEPOSIT_FINALITY_CONFIRMATIONS=20
BNB_BSC_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0

# Stablecoins. Prefer Graph addresses for direct stablecoin settlement.
USDC_DEPOSIT_NETWORK=ethereum
USDC_ETH_DEPOSIT_ADDRESS=
GRAPH_USDC_ETH_DEPOSIT_ADDRESS=
BINANCE_USDC_ETH_DEPOSIT_ADDRESS=
BYBIT_USDC_ETH_DEPOSIT_ADDRESS=
USDC_ETH_RPC_URL=
USDC_ETH_CONTRACT=0xA0b86991c6218b36c1d19d4a2e9eb0ce3606eb48
USDC_ETH_DEPOSIT_DETECTION_CONFIRMATIONS=1
USDC_ETH_DEPOSIT_FINALITY_CONFIRMATIONS=12
USDC_ETH_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0
USDC_POLYGON_DEPOSIT_ADDRESS=
GRAPH_USDC_POLYGON_DEPOSIT_ADDRESS=
BINANCE_USDC_POLYGON_DEPOSIT_ADDRESS=
BYBIT_USDC_POLYGON_DEPOSIT_ADDRESS=
USDC_POLYGON_RPC_URL=
USDC_POLYGON_CONTRACT=0x3c499c542cef5e3811e1192ce70d8cc03d5c3359
USDC_POLYGON_DEPOSIT_DETECTION_CONFIRMATIONS=1
USDC_POLYGON_DEPOSIT_FINALITY_CONFIRMATIONS=64
USDC_POLYGON_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0

USDT_DEPOSIT_NETWORK=ethereum
USDT_ETH_DEPOSIT_ADDRESS=
GRAPH_USDT_ETH_DEPOSIT_ADDRESS=
BINANCE_USDT_ETH_DEPOSIT_ADDRESS=
BYBIT_USDT_ETH_DEPOSIT_ADDRESS=
USDT_ETH_RPC_URL=
USDT_ETH_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_ETH_DEPOSIT_DETECTION_CONFIRMATIONS=1
USDT_ETH_DEPOSIT_FINALITY_CONFIRMATIONS=12
USDT_ETH_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0
USDT_POLYGON_DEPOSIT_ADDRESS=
GRAPH_USDT_POLYGON_DEPOSIT_ADDRESS=
BINANCE_USDT_POLYGON_DEPOSIT_ADDRESS=
BYBIT_USDT_POLYGON_DEPOSIT_ADDRESS=
USDT_POLYGON_RPC_URL=
USDT_POLYGON_CONTRACT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDT_POLYGON_DEPOSIT_DETECTION_CONFIRMATIONS=1
USDT_POLYGON_DEPOSIT_FINALITY_CONFIRMATIONS=64
USDT_POLYGON_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0
USDT_BSC_DEPOSIT_ADDRESS=
GRAPH_USDT_BSC_DEPOSIT_ADDRESS=
BINANCE_USDT_BSC_DEPOSIT_ADDRESS=
BYBIT_USDT_BSC_DEPOSIT_ADDRESS=
USDT_BSC_RPC_URL=
USDT_BSC_CONTRACT=0x55d398326f99059fF775485246999027B3197955
USDT_BSC_DEPOSIT_DETECTION_CONFIRMATIONS=1
USDT_BSC_DEPOSIT_FINALITY_CONFIRMATIONS=20
USDT_BSC_DEPOSIT_AMOUNT_TOLERANCE_MINOR=0

DEPOSIT_BACKFILL_LOOKBACK_BLOCKS=9000

# Never configure private key material in env. Production address generation
# must use provider-managed addresses or Vault/HSM-backed wallet services.
